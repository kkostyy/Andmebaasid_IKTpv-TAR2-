End Sub

Sub KysiLaenAI()
    Dim S As Variant
    Dim Y As Variant
    Dim P As Variant
    Dim tulemus As Variant

    ' Kьsi laenusumma
    S = InputBox("Sisesta laenu summa (Ђ):", "Laen AI arvutus")
    If S = "" Then
        MsgBox "Sisestamine katkestati.", vbExclamation
        Exit Sub
    End If

    ' Kьsi aastate arv
    Y = InputBox("Sisesta aastate arv:", "Laen AI arvutus")
    If Y = "" Then
        MsgBox "Sisestamine katkestati.", vbExclamation
        Exit Sub
    End If

    ' Kьsi intress (%)
    P = InputBox("Sisesta aastane intress (%):", "Laen AI arvutus")
    If P = "" Then
        MsgBox "Sisestamine katkestati.", vbExclamation
        Exit Sub
    End If

    ' Kontrolli, kas sisendid on numbrid
    If Not IsNumeric(S) Or Not IsNumeric(Y) Or Not IsNumeric(P) Then
        MsgBox "Sisesta ainult numbrid!", vbCritical
        Exit Sub
    End If

    ' Kutsub sinu funktsiooni
    tulemus = LaenAI(CDbl(S), CInt(Y), CDbl(P))

    ' Kontrollime, kas funktsioon tagastas vea (#VALUE!)
    If IsError(tulemus) Then
        MsgBox "Viga! Kхik vддrtused peavad olema positiivsed.", vbCritical
        Exit Sub
    End If

    ' Kuvame lхpptulemuse
    MsgBox "Lхplik tasumata laenusumma: " & Format(tulemus, "0.00 Ђ"), _
           vbInformation, "Laen AI tulemus"

End Sub
