    x = InputBox("Sisesta kaateti a pikkus:", "Pythagoras AI")
    If x = "" Then
        MsgBox "Sisestamine katkestati.", vbExclamation
        Exit Sub
    End If

    ' Kьsime kaateti b pikkuse
    Y = InputBox("Sisesta kaateti b pikkus:", "Pythagoras AI")
    If Y = "" Then
        MsgBox "Sisestamine katkestati.", vbExclamation
        Exit Sub
    End If

    ' Kontrollime numbrilisust
    If Not IsNumeric(x) Or Not IsNumeric(Y) Then
        MsgBox "Sisesta ainult numbrid!", vbCritical
        Exit Sub
    End If

    ' Kutsub sinu funktsiooni
    tulemus = PifagorAI(CDbl(x), CDbl(Y))

