' Funktsioon, mis leiab isikukoodi pohjal sunnikuu nime
Public Function Sunnikuu(ByVal isikukood As String) As Variant
    ' 1. KONTROLL: Isikukood peab olema tapselt 11 marki pikk
    If Len(isikukood) <> 11 Then
        Sunnikuu = CVErr(xlErrValue) ' Kui pikkus on vale, tagastab vea #VALUE!
        Exit Function
    End If

    ' 2. ERALDAMINE: Votame isikukoodist 4. ja 5. margi (kuu number)
    ' Mid(isikukood, 4, 2) tahendab: alusta 4. positsioonist ja vota 2 sumbolit
    Dim kuuNr As Integer
    kuuNr = Val(Mid(isikukood, 4, 2))

    ' 3. VALIK: Kasutame Select Case konstruktsiooni nime leidmiseks
    Select Case kuuNr
        Case 1: Sunnikuu = "jaanuar"
        Case 2: Sunnikuu = "veebruar"
        Case 3: Sunnikuu = "marts"
        Case 4: Sunnikuu = "aprill"
        Case 5: Sunnikuu = "mai"
        Case 6: Sunnikuu = "juuni"
        Case 7: Sunnikuu = "juuli"
        Case 8: Sunnikuu = "august"
        Case 9: Sunnikuu = "september"
        Case 10: Sunnikuu = "oktoober"
        Case 11: Sunnikuu = "november"
        Case 12: Sunnikuu = "detsember"
        Case Else
            ' Kui kuu number ei ole 1-12 vahemikus
            Sunnikuu = CVErr(xlErrValue)
    End Select
End Function


' Tagastab sünnikuu nime isikukoodi põhjal
Public Function SunnikuuAl(ByVal isikukood As String) As Variant
    ' Kontroll: isikukood peab olema 11 märki pikk
    If Len(isikukood) <> 11 Then
        SunnikuuAl = CVErr(xlErrValue)
        Exit Function
    End If

    ' Eraldame 4. ja 5. märgi (kuu number)
    Dim kuuNr As Integer
    kuuNr = Val(Mid(isikukood, 4, 2))

    ' Kontroll: kuu number peab olema vahemikus 1-12
    If kuuNr < 1 Or kuuNr > 12 Then
        SunnikuuAl = CVErr(xlErrValue)
        Exit Function
    End If
    

    ' Tagastab kuu nime (True tähendab täispikka nime)
    SunnikuuAl = MonthName(kuuNr, False)
End Function
'ise kirjutatud
Public Function Sistema(x As Double) As Double
    If x < -5 Or x > 5 Then
        Sistema = 1 / (5 - x * x)
    Else
        Sistema = Cos(x)
    End If
End Function
'Al abil
Public Function SistemaAl(x As Double) As Double
    Select Case True
        Case Abs(x) > 5
            SistemaAl = 1 / (5 - x ^ 2)
        Case Else
            SistemaAl = Cos(x)
    End Select
End Function
