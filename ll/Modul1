Function komission(puudumised As Integer, kehviHindeid As Integer) As String

    ' Otsustame vastavalt tingimustele
    If puudumised > 40 And kehviHindeid >= 3 Then
        komission = "Välja!"

    ElseIf puudumised = 0 And kehviHindeid = 0 Then
        komission = "Kiitus!"

    ElseIf puudumised < 40 And kehviHindeid < 3 Then
        komission = "Noomitus!"

    Else
        ' Kui jääb mõni muu kombinatsioon (nt >40 puudumist, aga <3 halba hinnet)
        komission = "Küsimus arutamiseks komisjonis."
    End If

End Function

Function komissionAI(puudumised As Integer, kehviHindeid As Integer) As String

    Select Case True

        Case puudumised > 40 And kehviHindeid >= 3
            komissionAI = "Välja!"

        Case puudumised = 0 And kehviHindeid = 0
            komissionAI = "Kiitus!"

        Case puudumised < 40 And kehviHindeid < 3
            komissionAI = "Noomitus!"

        Case Else
            komissionAI = "Küsimus arutamiseks komisjonis."

    End Select

End Function

Function nettopalk(tunnitasu As Double, tunnid As Double) As Double
    Dim bruto As Double
    Dim tmv As Double         ' tulumaksuvaba miinimum
    Dim maksustatav As Double
    Dim tulumaks As Double

    bruto = tunnitasu * tunnid

    ' --- Tulumaksuvaba miinimum ---
    If bruto <= 1200 Then
        tmv = 545
    ElseIf bruto >= 2100 Then
        tmv = 0
    Else
        tmv = 545 - 545 / (2100 - 1200) * (bruto - 1200)
    End If

    maksustatav = bruto - tmv
    If maksustatav < 0 Then maksustatav = 0

    tulumaks = maksustatav * 0.2

    nettopalk = bruto - tulumaks
End Function

Function nettopalkAI(tunnitasu As Double, tunnid As Double) As Double
    Dim bruto As Double
