End Function

Function Kolmnurga_kontroll(a As Double, b As Double, c As Double) As String
    Dim suurim As Double, x As Double, Y As Double

    ' Kontroll: kas kolmnurk saab eksisteerida
    If a + b <= c Or a + c <= b Or b + c <= a Then
        Kolmnurga_kontroll = "Kolmnurk ei eksisteeri."
        Exit Function
    End If

    ' Leiame suurima külje
    suurim = a
    x = b: Y = c
    If b > suurim Then suurim = b: x = a: Y = c
    If c > suurim Then suurim = c: x = a: Y = b

    ' Teravnurkne kui suurim² < x² + y²
    If suurim ^ 2 < x ^ 2 + Y ^ 2 Then
        Kolmnurga_kontroll = "Kolmnurk on teravnurkne."
    Else
        Kolmnurga_kontroll = "Kolmnurk ei ole teravnurkne."
    End If
End Function

Function Kolmnurga_kontrollAI(a As Double, b As Double, c As Double) As String
    Dim suurim As Double, x As Double, Y As Double

    ' Esmalt kontrollime, kas kolmnurk üldse saab eksisteerida
    Select Case True
        Case a + b <= c Or a + c <= b Or b + c <= a
            Kolmnurga_kontrollAI = "Kolmnurk ei eksisteeri."
            Exit Function
    End Select

    ' Leiame suurima külje
    suurim = a: x = b: Y = c
    If b > suurim Then suurim = b: x = a: Y = c
    If c > suurim Then suurim = c: x = a: Y = b

    ' Kontroll teravnurksuse kohta
    Select Case True
        Case suurim ^ 2 < x ^ 2 + Y ^ 2
            Kolmnurga_kontrollAI = "Kolmnurk on teravnurkne."
        Case Else
            Kolmnurga_kontrollAI = "Kolmnurk ei ole teravnurkne."
    End Select
End Function

Function Pifagor(a As Double, b As Double) As Double
    If a < 0 Or b < 0 Then
        Pifagor = CVErr(xlErrValue)
    Else
        Pifagor = Sqr(a ^ 2 + b ^ 2)
    End If
End Function

Function PifagorAI(a As Double, b As Double) As Double

    Select Case True
        Case a < 0 Or b < 0
            PifagorAI = CVErr(xlErrValue)

        Case Else
            PifagorAI = Sqr(a ^ 2 + b ^ 2)
    End Select

End Function


    

