' liitintressi arvutaja
' ise kirjutatud
Public Function Laen(Summa, Aastad, Pros)
    For i = 0 To Aastad Step 1
        Summa = Summa + Summa * (Pros / 100)
    Next i
    Laen = Summa
End Function


Function LaenAI(Summa As Double, Aastad As Integer, Pros As Double) As Variant

    If Summa <= 0 Or Aastad < 0 Or Pros < 0 Then
        LaenAI = CVErr(xlErrValue)
        Exit Function
    End If

    Dim i As Integer

    For i = 0 To Aastad Step 1
        Summa = Summa + Summa * (Pros / 100)
    Next i

    LaenAI = Summa

End Function
