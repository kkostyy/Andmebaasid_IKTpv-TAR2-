' taisnurkse kolmnurga pindala AI abil
Public Function PindalaAI(ByVal a As Double, ByVal b As Double) As Variant
    ' Kontroll: molemad vaartused peavad olema positiivsed
    If a <= 0 Or b <= 0 Then
        PindalaAI = CVErr(xlErrValue) ' Tagastab Exceli #VALUE! vea
        Exit Function
    End If
    ' Arvutamine
    PindalaAI = (a * b) / 2
End Function
Function perimetr(a, b, c)
    perimetr = a + b + c
End Function

Public Function PerimetrAI(ByVal a As Double, ByVal b As Double, ByVal c As Double) As Variant
    ' Kontroll: kuljed peavad olema positiivsed ja moodustama kolmnurga
    If a <= 0 Or b <= 0 Or c <= 0 Or (a + b <= c) Or (a + c <= b) Or (b + c <= a) Then
        PerimetrAI = CVErr(xlErrValue)
        Exit Function
    End If

    ' Arvutamine: a + b + c
    PerimetrAI = a + b + c
End Function
' Funktsioon lisab hinnale käibemaksu (22%)
Public Function HindKaibemaksuga(hind)
